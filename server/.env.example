# ─────────────────────────────────────────────────────────────────
#  QSS Device Intake — Server Environment Config
#  Copy this file to .env and fill in your values.
#  .env is gitignored — never commit your actual .env file.
# ─────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────
# IP address this server listens on.
# 0.0.0.0 means "all interfaces" — required so the Quest can reach
# this PC over WiFi. Use 127.0.0.1 to restrict to localhost only.
HOST=0.0.0.0

# Port the Flask server runs on.
# Must match DataSyncManager._serverBaseUrl in the Unity project.
PORT=5000

# ── Output Folders ───────────────────────────────────────────────
# Where Excel reports are saved (relative to server/ or absolute path).
OUTPUT_DIR=output

# Where ZPL sticker files are saved (one .zpl per box, used for reprints).
STICKER_DIR=stickers

# ── Printer ──────────────────────────────────────────────────────
# Exact name of the Zebra printer as it appears in Windows.
# To find it:  Start → Settings → Bluetooth & devices → Printers & scanners
# Copy the name exactly, including spaces and capitalisation.
# Examples:
#   PRINTER_NAME=ZDesigner ZD421
#   PRINTER_NAME=Zebra ZT411 (USB)
#   PRINTER_NAME=\\PRINT-SERVER\ZebraLabel   (network share)
PRINTER_NAME=ZDesigner ZD421

# ── Claude / Anthropic ───────────────────────────────────────────
# API key from https://console.anthropic.com/
# Used for:
#   • Vision OCR  — /api/ocr endpoint (reads box labels via camera frames)
#   • Result parser — /api/parse-result endpoint (interprets PS test output)
ANTHROPIC_API_KEY=sk-ant-...
